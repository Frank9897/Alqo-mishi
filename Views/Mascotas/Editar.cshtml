@model AlqoMishi.Entidades.Mascota

<h2>Editar mascota</h2>

<form asp-action="Editar">

<input type="hidden" asp-for="Id" />

<div class="mb-3">
<label>Nombre</label>
<input asp-for="Nombre" class="form-control">
</div>

<div class="mb-3">
<label>Especie</label>
<input asp-for="Especie" class="form-control">
</div>

<div class="mb-3">
<label>Raza</label>
<input asp-for="Raza" class="form-control">
</div>

<div class="mb-3">
<label>Edad</label>
<input asp-for="Edad" class="form-control">
</div>

<div class="mb-3">
<label>Sexo</label>
<select asp-for="Sexo" class="form-control">
<option>Macho</option>
<option>Hembra</option>
</select>
</div>

<button class="btn btn-success">
Guardar
</button>

<a asp-action="MisMascotas" class="btn btn-secondary">
Volver
</a>

</form>