@model AlqoMishi.Entidades.Mascota

<h2>Historial médico de @Model.Nombre</h2>

<hr />

@if (!Model.HistorialesMedicos.Any())
{
    <div class="alert alert-info">
        Esta mascota aún no tiene historial médico.
    </div>
}
else
{
    <table class="table table-striped">

        <thead>
            <tr>
                <th>Fecha</th>
                <th>Diagnóstico</th>
                <th>Tratamiento</th>
                <th>Medicamentos</th>
                <th>Peso</th>
                <th>Temperatura</th>
            </tr>
        </thead>

        <tbody>
        @foreach (var h in Model.HistorialesMedicos.OrderByDescending(x => x.Fecha))
        {
            <tr>
                <td>@h.Fecha.ToString("dd/MM/yyyy")</td>
                <td>@h.Diagnostico</td>
                <td>@h.Tratamiento</td>
                <td>@h.Medicamentos</td>
                <td>@h.Peso</td>
                <td>@h.Temperatura</td>
            </tr>
        }
        </tbody>

    </table>
}