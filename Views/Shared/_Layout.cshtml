@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using AlqoMishi.Entidades
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AlqoMishi</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AlqoMishi.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

<div class="container-fluid">

<a class="navbar-brand"
asp-controller="Home"
asp-action="Index">

🐾 AlqoMishi

</a>

<button class="navbar-toggler"
type="button"
data-bs-toggle="collapse"
data-bs-target="#navbarMain">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse" id="navbarMain">

<ul class="navbar-nav me-auto">

    <li class="nav-item">
        <a class="nav-link" asp-controller="Home" asp-action="Index">
            Inicio
        </a>
    </li>


    @if (User.IsInRole("Cliente") || !User.Identity.IsAuthenticated)
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Turnos" asp-action="Index">
                Turnos
            </a>
        </li>

        @if (User.Identity.IsAuthenticated)
        {
            <li class="nav-item">
                <a class="nav-link" asp-controller="Mascotas" asp-action="Index">
                    Mascotas
                </a>
            </li>
        }
    }


    @if (User.IsInRole("Admin"))
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="Empleados">
                Veterinarios
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="Franjas">
                Franjas horarias
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="Turnos">
                Turnos
            </a>
        </li>
    }


    @if (User.IsInRole("Empleado"))
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Empleado" asp-action="Agenda">
                Mi agenda
            </a>
        </li>
    }

</ul>

<ul class="navbar-nav">

@if (User.Identity.IsAuthenticated)
{

<li class="nav-item">

@inject UserManager<Usuario> UserManager

<span class="navbar-text me-3">

@{
    var usuario = await UserManager.GetUserAsync(User);
}

Hola @(usuario?.Nombre ?? User.Identity.Name)

</span>

</li>

<li class="nav-item">

<form asp-controller="Account"
asp-action="CerrarSesion"
method="post">

<button class="btn btn-outline-light btn-sm">

Cerrar sesión

</button>

</form>

</li>

}
else
{

<li class="nav-item">

<a class="nav-link"
asp-controller="Account"
asp-action="Login">

Iniciar sesión

</a>

</li>

<li class="nav-item">

<a class="nav-link"
asp-controller="Account"
asp-action="Registro">

Registrarse

</a>

</li>

}

</ul>

</div>

</div>

</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - AlqoMishi - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
