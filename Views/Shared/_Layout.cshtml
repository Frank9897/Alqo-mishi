@using Microsoft.AspNetCore.Identity
@using AlqoMishi.Entidades
@inject UserManager<Usuario> UserManager
@inject IConfiguration Configuration


<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>@ViewData["Title"] - AlqoMishi</title>

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/site.palette.css" asp-append-version="true">
<style>

/* hero veterinaria */

.hero-vet
{
background: linear-gradient(135deg,#f39b5b,#f29859);
color:white;
padding:40px 20px;
border-radius:10px;
margin-bottom:25px;
}

.hero-vet h1
{
font-size:28px;
font-weight:600;
}

.hero-vet p
{
opacity:0.9;
margin-top:10px;
}

/* footer */

.footer
{
background:#f8f9fa;
padding:15px;
font-size:14px;
}

</style>

</head>

<body>

<header>

<nav class="navbar navbar-expand-lg navbar-alqo shadow-sm">

<div class="container-fluid">

<a class="navbar-brand fw-bold"
asp-controller="Home"
asp-action="Index">

🐾 AlqoMishi

</a>

<button class="navbar-toggler"
type="button"
data-bs-toggle="collapse"
data-bs-target="#navbarMain">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse" id="navbarMain">

<ul class="navbar-nav me-auto">

<li class="nav-item">
<a class="nav-link" asp-controller="Home" asp-action="Index">
Inicio
</a>
</li>


@if (!User.Identity.IsAuthenticated)
{
<li class="nav-item">
<a class="nav-link" asp-controller="Turnos" asp-action="Index">
Turnos
</a>
</li>
}


@if (User.IsInRole("Cliente"))
{
<li class="nav-item">
<a class="nav-link" asp-controller="Turnos" asp-action="Index">
Turnos
</a>
</li>

<li class="nav-item dropdown">

<a class="nav-link dropdown-toggle"
data-bs-toggle="dropdown">

Mis datos

</a>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item"
asp-controller="Mascotas"
asp-action="MisMascotas">
Mis Mascotas
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Turnos"
asp-action="Historial">
Historial
</a>
</li>

</ul>

</li>
}


@if (User.IsInRole("Empleado"))
{

<li class="nav-item">
<a class="nav-link" asp-controller="Turnos" asp-action="Index">
Turnos
</a>
</li>

<li class="nav-item">
<a class="nav-link"
asp-controller="Veterinario"
asp-action="Agenda">
Mi Agenda
</a>
</li>

}


@if (User.IsInRole("Admin"))
{

<li class="nav-item">
<a class="nav-link" asp-controller="Turnos" asp-action="Index">
Turnos
</a>
</li>

<li class="nav-item dropdown">

<a class="nav-link dropdown-toggle"
data-bs-toggle="dropdown">

Administración

</a>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item"
asp-controller="Admin"
asp-action="Empleados">
Veterinarios
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Admin"
asp-action="Franjas">
Franjas horarias
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Admin"
asp-action="Turnos">
Turnos
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Admin"
asp-action="Usuarios">
Usuarios
</a>
</li>

<li>
<a class="dropdown-item"
   asp-controller="Admin"
   asp-action="HistorialAtenciones">
   Rendimiento de atención por empleado
</a>
</li>
<li>
<a class="dropdown-item"
   asp-controller="Admin"
   asp-action="HistorialAtencionesDetalle">
   Historial de Atenciones
</a>
</li>

</ul>

</li>

}

</ul>


<ul class="navbar-nav">

@if (User.Identity.IsAuthenticated)
{

<li class="nav-item d-flex align-items-center me-3">

@{
var user = await UserManager.GetUserAsync(User);
}

@if (user != null)
{
<span class="nav-user-box">
👤 Hola @user.Nombre @user.Apellido
</span>
}

</li>


<li class="nav-item">

<form asp-controller="Account"
asp-action="CerrarSesion"
method="post">

<button class="btn btn-logout btn-sm">
Cerrar sesión
</button>


</form>

</li>

}
else
{

<li class="nav-item">

<a class="nav-link"
asp-controller="Account"
asp-action="Login">

Iniciar sesión

</a>

</li>

<li class="nav-item">

<a class="nav-link"
asp-controller="Account"
asp-action="Registro">

Registrarse

</a>

</li>

}

</ul>

</div>

</div>

</nav>


</header>


<div class="container mt-4">


<div class="hero-vet">

<h1>Clínica Veterinaria AlqoMishi</h1>

<p>

Cuidamos la salud y bienestar de tus mascotas con atención veterinaria profesional.
Gestiona turnos, historial médico y seguimiento clínico en un solo lugar.

</p>

</div>


<main role="main">

@RenderBody()

</main>

</div>



<footer class="footer mt-5 border-top">

<div class="container text-center">

© 2026 - Clínica Veterinaria AlqoMishi  

<br>

Sistema de gestión veterinaria para atención clínica y seguimiento de mascotas.

<br>

<a asp-controller="Home" asp-action="Privacy">
Política de privacidad
</a>

</div>

</footer>



<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)
<script src="~/js/toasts.js"></script>

<script>
var serverToast = '@Html.Raw(TempData["Toast"] ?? "")';

if(serverToast){
    showToastFromServer(serverToast);
}
</script>
</body>

@{
    var telefono = Configuration["Contacto:WhatsApp"];
    var linkWhatsApp = $"https://wa.me/{telefono}?text=Hola%20quiero%20consultar%20sobre%20un%20turno";
}

<a href="@linkWhatsApp"
   target="_blank"
   class="whatsapp-btn"
   title="Contactar por WhatsApp">

    <img src="/icon/whatsapp.svg" class="whatsapp-icon"/>

</a>


</html>