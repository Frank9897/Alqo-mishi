@model IEnumerable<AlqoMishi.ViewModels.TurnoAdminViewModel>

<h2>Historial de turnos</h2>

<div class="card shadow-sm mb-4">

<div class="card-body">

<form method="get" class="row g-3">

<div class="col-md-3 col-12">
<label class="form-label">Fecha</label>
<input type="date" name="fecha" class="form-control">
</div>

<div class="col-md-3 col-12">
<label class="form-label">Veterinario</label>
<select name="veterinarioId" class="form-select">

<option value="">Todos</option>

@foreach (var vet in ViewBag.Veterinarios)
{
<option value="@vet.Id">
@vet.Usuario.Nombre @vet.Usuario.Apellido
</option>
}

</select>
</div>

<div class="col-md-2 col-12">
<label class="form-label">Estado</label>
<select name="estado" class="form-select">

<option value="">Todos</option>
<option>Reservado</option>
<option>En espera</option>
<option>Atendido</option>
<option>Cancelado</option>

</select>
</div>

<div class="col-md-2 col-12">
<label class="form-label">Mascota</label>
<input type="text"
name="mascota"
class="form-control"
placeholder="Buscar...">
</div>

<div class="col-md-2 col-12 d-flex align-items-end gap-2">

<button class="btn btn-primary w-100">
Filtrar
</button>

<a href="/Admin/Turnos" class="btn btn-outline-secondary w-100">
Limpiar
</a>

</div>

</form>

</div>
</div>

<div class="table-responsive">
<table class="table table-striped">

<thead>
<tr>
<th>Mascota</th>
<th>Cliente</th>
<th>Veterinario</th>
<th>Fecha</th>
<th>Hora</th>
<th>Estado</th>
<th>Precio</th>
<th></th>
</tr>
</thead>

<tbody>

@foreach(var turno in Model)
{
<tr>

<td>@turno.Mascota</td>

<td>@turno.Cliente</td>

<td>@turno.Veterinario</td>

<td>@turno.Fecha.ToShortDateString()</td>

<td>@turno.HoraInicio</td>

<td>
   @if (turno.Estado == "Reservado")
{
<span class="badge bg-primary">Reservado</span>
}

@if (turno.Estado == "En espera")
{
<span class="badge bg-warning text-dark">En espera</span>
}

@if (turno.Estado == "Atendido")
{
<span class="badge bg-success">Atendido</span>
}

@if (turno.Estado == "Cancelado")
{
<span class="badge bg-danger">Cancelado</span>
}

</td>

<td>$@turno.Precio</td>

<td>

<a class="btn btn-warning btn-sm"
   asp-action="EnEspera"
   asp-route-id="@turno.Id">

    En espera

</a>

<a class="btn btn-success btn-sm"
   asp-action="AtenderTurno"
   asp-route-id="@turno.Id">

    Atendido

</a>

<a asp-action="Atender" asp-route-id="@turno.Id"
   class="btn btn-primary btn-sm">
   Atender
</a>
<a asp-action="Historial"
   asp-route-mascotaId="@turno.MascotaId"
   class="btn btn-secondary btn-sm">

    Historial

</a>
<a class="btn btn-danger btn-sm"
   asp-action="CancelarTurno"
   asp-route-id="@turno.Id">

    Cancelar

</a>

</td>

</tr>
}

</tbody>

</table>
</div>