@model IEnumerable<AlqoMishi.ViewModels.TurnoAdminViewModel>

<h2>Historial de turnos</h2>

<form method="get" class="row mb-4">

<div class="col-md-3">
<label>Fecha</label>
<input type="date" name="fecha" class="form-control" />
</div>

<div class="col-md-3">
<label>Veterinario</label>
<select name="veterinarioId" class="form-control">

<option value="">Todos</option>

@foreach (var vet in ViewBag.Veterinarios)
{
<option value="@vet.Id">
@vet.Usuario.Nombre @vet.Usuario.Apellido
</option>
}

</select>
</div>

<div class="col-md-3">
<label>Estado</label>
<select name="estado" class="form-control">

<option value="">Todos</option>
<option>Reservado</option>
<option>En espera</option>
<option>Atendido</option>
<option>Cancelado</option>

</select>
</div>

<div class="col-md-3 d-flex align-items-end">

<button class="btn btn-primary w-100">
Filtrar
</button>

</div>

</form>

<table class="table table-striped">

<thead>
<tr>
<th>Mascota</th>
<th>Cliente</th>
<th>Veterinario</th>
<th>Fecha</th>
<th>Hora</th>
<th>Estado</th>
<th>Precio</th>
<th></th>
</tr>
</thead>

<tbody>

@foreach(var turno in Model)
{
<tr>

<td>@turno.Mascota</td>

<td>@turno.Cliente</td>

<td>@turno.Veterinario</td>

<td>@turno.Fecha.ToShortDateString()</td>

<td>@turno.HoraInicio</td>

<td>@turno.Estado</td>

<td>$@turno.Precio</td>

<td>

<a class="btn btn-warning btn-sm"
   asp-action="EnEspera"
   asp-route-id="@turno.Id">

    En espera

</a>

<a class="btn btn-success btn-sm"
   asp-action="AtenderTurno"
   asp-route-id="@turno.Id">

    Atendido

</a>

<a asp-action="Atender" asp-route-id="@turno.Id"
   class="btn btn-primary btn-sm">
   Atender
</a>
<a asp-action="Historial"
   asp-route-mascotaId="@turno.MascotaId"
   class="btn btn-secondary btn-sm">

    Historial

</a>
<a class="btn btn-danger btn-sm"
   asp-action="CancelarTurno"
   asp-route-id="@turno.Id">

    Cancelar

</a>

</td>

</tr>
}

</tbody>

</table>