@model List<AlqoMishi.Entidades.Usuario>

<h2>Usuarios del sistema</h2>
<a class="btn btn-primary mb-3"
asp-action="CrearUsuario">

➕ Nuevo Usuario

</a>
<table class="table">

<tr>
<th>Nombre</th>
<th>Email</th>
<th>Rol</th>
<th>Acciones</th>
</tr>

@foreach (var u in Model)
{
<tr>

<td>@u.Nombre @u.Apellido</td>
<td>@u.Email</td>
<td>@u.RolSistema</td>
<td>
<a asp-action="EditarUsuario"
asp-route-id="@u.Id"
class="btn btn-sm btn-primary">

Editar

</a>
</td>

</tr>
}

</table>