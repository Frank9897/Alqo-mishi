@model List<AlqoMishi.Entidades.Empleado>

<h2>Administración de Veterinarios</h2>

<a class="btn btn-primary mb-3" href="/Admin/CrearEmpleado">
    Nuevo veterinario
</a>

<table class="table table-striped table-hover">

<thead>
<tr>
<th>Especialidad</th>
<th>Disponible</th>
<th>Acciones</th>
</tr>
</thead>

<tbody>

@foreach(var emp in Model)
{
<tr>

<td>@emp.Especialidad</td>

<td>
@if(emp.EstaDisponible)
{
<span class="badge bg-success">Disponible</span>
}
else
{
<span class="badge bg-danger">No disponible</span>
}
</td>

<td>

<a class="btn btn-sm btn-warning"
href="/Admin/EditarEmpleado/@emp.Id">
Editar
</a>

<a class="btn btn-sm btn-danger"
href="/Admin/EliminarEmpleado/@emp.Id">
Eliminar
</a>

</td>

</tr>
}

</tbody>

</table>