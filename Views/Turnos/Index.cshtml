@{
    Layout = "_Layout";
}

<h2 class="mb-4">Sistema de Turnos - ALQO MISHI</h2>

<div class="container-fluid">
    <div id="calendario"></div>
</div>

<!-- MODAL RESERVA -->
<div class="modal fade" id="modalReserva" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Reservar turno</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="alert alert-info">

                    <strong>Horario seleccionado</strong><br>

                    Inicio: <span id="horaInicio"></span><br>
                    Fin: <span id="horaFin"></span>

                </div>


                <h6 class="mt-3">Mascota registrada</h6>

                <select id="mascotaId" class="form-control mb-3">
                    <option value="">Seleccionar mascota</option>
                </select>

                <div class="text-center mb-3">
                    <span class="text-muted">o registrar una nueva mascota</span>
                </div>


                <div class="card p-3 bg-light">

                    <h6 class="mb-3">Datos de la mascota</h6>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label>Nombre</label>

                            <input type="text"
                                class="form-control"
                                id="mascota"
                                placeholder="Ej: Firulais">

                        </div>

                        <div class="col-md-6 mb-3">

                            <label>Especie</label>

                            <input type="text"
                                class="form-control"
                                id="especie"
                                placeholder="Ej: Perro">

                        </div>

                    </div>


                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label>Raza</label>

                            <input type="text"
                                class="form-control"
                                id="raza"
                                placeholder="Ej: Labrador">

                        </div>

                        <div class="col-md-6 mb-3">

                            <label>Edad aproximada</label>

                            <input type="number"
                                class="form-control"
                                id="edad"
                                placeholder="Ej: 5">

                        </div>

                    </div>


                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label>Sexo</label>

                            <select id="sexo" class="form-control">

                                <option value="">Seleccionar</option>
                                <option value="Macho">Macho</option>
                                <option value="Hembra">Hembra</option>

                            </select>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label>Notas médicas</label>

                            <input type="text"
                                class="form-control"
                                id="notas"
                                placeholder="Ej: alergia a penicilina">

                        </div>

                    </div>

                    <div class="mt-3">

                        <label>Observaciones del turno</label>

                        <textarea
                            class="form-control"
                            id="observaciones"
                            rows="3"
                            placeholder="Ej: consulta general, vacunación, control, vómitos, revisión..."></textarea>

                    </div>

                </div>



            </div>

            <div class="modal-footer">

               <button class="btn btn-success w-100" id="btnConfirmar">

                    <i class="bi bi-calendar-check"></i>

                    Confirmar turno

                </button>

            </div>

        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/main.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/locales/es.global.min.js"></script>

<script>

document.addEventListener('DOMContentLoaded', function () {

    let franjaSeleccionada = null;

    var calendarioEl = document.getElementById('calendario');

    var calendario = new FullCalendar.Calendar(calendarioEl, {

        locale: 'es',

        slotMinTime: "08:00:00",
        slotMaxTime: "20:00:00",

        initialView: 'dayGridMonth',

        height: "auto",

        events: '/Turnos/ObtenerFranjas',

        allDayText: 'Todo el día',

        buttonText: {
            today: 'Hoy',
            month: 'Mes',
            week: 'Semana',
            day: 'Día'
        },

        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek,timeGridDay'
        },

        eventDidMount: function(info) {

            info.el.querySelector(".fc-event-title")
                .innerHTML = info.event.title.replace(/\n/g, "<br>");

        },

        eventClick: function(info) {

            if(info.event.title.includes("COMPLETO")){
                alert("Esta franja ya no tiene cupos disponibles");
                return;
            }

            franjaSeleccionada = info.event.id;

            let inicio = info.event.start.toLocaleTimeString();
            let fin = info.event.end.toLocaleTimeString();

            document.getElementById("horaInicio").innerText = inicio;
            document.getElementById("horaFin").innerText = fin;

            let modal = new bootstrap.Modal(
                document.getElementById('modalReserva')
            );

            modal.show();

            cargarMascotas();

        }

    });

    calendario.render();


    async function cargarMascotas(){

        try{

            const response = await fetch("/api/mascotas");

            if(!response.ok) return;

            const mascotas = await response.json();

            let select = document.getElementById("mascotaId");

            select.innerHTML = '<option value="">Seleccionar mascota</option>';

            mascotas.forEach(m => {

                let option = document.createElement("option");

                option.value = m.id;

                option.text = m.nombre;

                select.appendChild(option);

            });

        }catch{
            console.log("Usuario no logueado o sin mascotas");
        }

    }


document.getElementById("btnConfirmar")
.addEventListener("click", async function(){

    let mascotaId = document.getElementById("mascotaId").value;

    let payload = {

        franjaId: franjaSeleccionada,

        mascotaId: mascotaId ? parseInt(mascotaId) : null,

        mascota: document.getElementById("mascota").value,

        especie: document.getElementById("especie").value,

        raza: document.getElementById("raza").value,

        edad: document.getElementById("edad").value || null,

        sexo: document.getElementById("sexo").value,

        notas: document.getElementById("notas").value,

        observaciones: document.getElementById("observaciones").value

    };

    const res = await fetch("/Turnos/ReservarTurno", {

        method: "POST",

        headers: {
            "Content-Type": "application/json"
        },

        body: JSON.stringify(payload)

    });

    if(res.ok){

        alert("Turno reservado correctamente");

        location.reload();

    }else{

        const error = await res.text();

        alert(error);

    }

});

});

</script>